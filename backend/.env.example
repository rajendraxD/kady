# ─── Server ────────────────────────────────────────────────────────────
# Port the backend server listens on (default: 5000)
PORT=5000

# ─── MongoDB ───────────────────────────────────────────────────────────
# MongoDB connection URI (default: mongodb://localhost:27017/kady-hiring-portal)
MONGO_URI=mongodb://localhost:27017/kady-hiring-portal

# ─── JWT ───────────────────────────────────────────────────────────────
# Secret key used to sign and verify JWT tokens (change in production!)
JWT_SECRET=kady-admin-secret-key-change-in-production

# ─── SMTP (Email) ──────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com    #izhanpinjari@gmail.com
SMTP_PASS=your-email-password
SMTP_FROM=no-replay@gmail.com  #User Management <izhanpinjari@gmail.com>
